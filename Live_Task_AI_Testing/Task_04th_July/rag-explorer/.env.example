# ============================================
# RAG Explorer Environment Configuration
# ============================================

# Required: Groq API key for LLM answer generation
# Get yours at: https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# Optional: Ollama URL for high-quality embeddings
# Leave empty or unset on Render/Railway/cloud — app falls back to hash-based embeddings
OLLAMA_URL=http://localhost:11434

# Optional: ChromaDB URL for persistent vector storage
# Leave empty or unset on Render/Railway/cloud — app falls back to in-memory store
CHROMA_URL=http://localhost:8000

# Server port (set automatically on Render — no need to change)
PORT=3001

# Set to 'production' when deploying to Render or other cloud platforms
NODE_ENV=production
