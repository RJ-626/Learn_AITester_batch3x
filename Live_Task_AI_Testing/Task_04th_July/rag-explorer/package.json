{
  "name": "rag-explorer",
  "version": "1.1.0",
  "description": "RAG Explorer - End-to-end RAG pipeline with React + Express + ChromaDB + Ollama + Groq. Now supports PDF, text files, code files, and URLs. 24/7 production ready.",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server/index.js",
    "install-service": "node install-windows-service.cjs",
    "uninstall-service": "node uninstall-windows-service.cjs"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "chromadb": "^1.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "groq-sdk": "^0.15.0",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "node-windows": "^1.0.0-beta.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.7"
  }
}
